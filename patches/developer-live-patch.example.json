{
  "schemaVersion": 1,
  "patchId": "developer-config-d-1",
  "channel": "developer",
  "sequence": 3,
  "appVersionRange": ">=0.5.2 <0.5.3",
  "lifetimeDays": 7,
  "statusColors": {
    "schemaVersion": 1,
    "metrics": {
      "cpu": {
        "unit": "%",
        "rules": [
          { "minInclusive": 0, "maxExclusive": 80, "color": "green" },
          { "minInclusive": 80, "maxExclusive": 90, "color": "yellow" },
          { "minInclusive": 90, "maxExclusive": 94, "color": "red" },
          { "minInclusive": 94, "maxExclusive": null, "color": "purple" }
        ]
      },
      "gpu": {
        "unit": "%",
        "rules": [
          { "minInclusive": 0, "maxExclusive": 80, "color": "green" },
          { "minInclusive": 80, "maxExclusive": 90, "color": "yellow" },
          { "minInclusive": 90, "maxExclusive": 96, "color": "red" },
          { "minInclusive": 96, "maxExclusive": null, "color": "purple" }
        ]
      },
      "ram": {
        "unit": "%",
        "rules": [
          { "minInclusive": 0, "maxExclusive": 70, "color": "green" },
          { "minInclusive": 70, "maxExclusive": 80, "color": "yellow" },
          { "minInclusive": 80, "maxExclusive": 90, "color": "red" },
          { "minInclusive": 90, "maxExclusive": null, "color": "purple" }
        ]
      },
      "temp": {
        "unit": "°C",
        "rules": [
          { "minInclusive": 0, "maxExclusive": 70, "color": "green" },
          { "minInclusive": 70, "maxExclusive": 80, "color": "yellow" },
          { "minInclusive": 80, "maxExclusive": 95, "color": "red" },
          { "minInclusive": 95, "maxExclusive": null, "color": "purple" }
        ]
      },
      "wifi": {
        "unit": "ms",
        "rules": [
          { "minInclusive": 0, "maxExclusive": 25, "color": "green" },
          { "minInclusive": 25, "maxExclusive": 35, "color": "yellow" },
          { "minInclusive": 35, "maxExclusive": 45, "color": "red" },
          { "minInclusive": 45, "maxExclusive": null, "color": "purple" }
        ]
      }
    },
    "offline": {
      "color": "red",
      "showSlash": true
    },
    "unavailable": {
      "color": "gray"
    }
  },
  "refreshPolicy": {
    "schemaVersion": 1,
    "timezone": "local",
    "dayMinutesSource": "settings",
    "night": {
      "start": "00:00",
      "end": "06:00",
      "refreshMinutes": 30
    },
    "manualRefresh": true
  },
  "settingsLayout": {
    "schemaVersion": 1,
    "title": "Settings",
    "fieldOrder": [
      "anthropicApiKey",
      "composioMcpToken",
      "refreshMinutes",
      "updateChannel"
    ],
    "labels": {
      "anthropicApiKey": "Anthropic API Key",
      "composioMcpToken": "Composio MCP Token",
      "refreshMinutes": "Refresh time",
      "updateChannel": "Update channel"
    }
  }
}
