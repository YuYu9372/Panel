{
  "appId": "com.sirius.panel",
  "productName": "Panel",
  "artifactName": "panel-0.5.1A-Public.${ext}",
  "directories": {
    "output": "dist"
  },
  "files": [
    "electron/**/*",
    "package.json"
  ],
  "extraResources": [
    { "from": "serve.py", "to": "panel/serve.py" },
    { "from": "macos_sensors.py", "to": "panel/macos_sensors.py" },
    { "from": "THIRD_PARTY_NOTICES.md", "to": "panel/THIRD_PARTY_NOTICES.md" },
    { "from": "index.html", "to": "panel/index.html" },
    { "from": "style.css", "to": "panel/style.css" },
    { "from": "app.js", "to": "panel/app.js" },
    { "from": "widgets", "to": "panel/widgets" },
    { "from": ".env.example", "to": "panel/.env" }
  ],
  "mac": {
    "target": "dmg",
    "category": "public.app-category.utilities"
  }
}
