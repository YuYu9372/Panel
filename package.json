{
  "name": "panel",
  "version": "0.5.2-alpha.1",
  "description": "Panel — personal dashboard, packaged as a macOS app.",
  "author": "Sirius",
  "license": "UNLICENSED",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg",
    "test:node": "node --test tests-js/*.test.js",
    "test:python": "python3 -m unittest discover -s tests -v",
    "test": "npm run test:node && npm run test:python"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.sirius.panel",
    "productName": "Panel",
    "artifactName": "panel-0.5.2-A.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      { "from": "serve.py", "to": "panel/serve.py" },
      { "from": "macos_sensors.py", "to": "panel/macos_sensors.py" },
      { "from": "THIRD_PARTY_NOTICES.md", "to": "panel/THIRD_PARTY_NOTICES.md" },
      { "from": "index.html", "to": "panel/index.html" },
      { "from": "style.css", "to": "panel/style.css" },
      { "from": "app.js", "to": "panel/app.js" },
      { "from": "widgets", "to": "panel/widgets" }
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.utilities"
    }
  }
}
